#include <Arduino.h>

// ==========================================
// 1. PIN DEFINITIONS
// ==========================================
const int ENA_PIN = 19; 
const int IN1_PIN = 21; 
const int IN2_PIN = 18; 
const int ENB_PIN = 4;  
const int IN3_PIN = 27; // Ensure this is 27 as per your board
const int IN4_PIN = 2;  

const int FRONT_TRIG = 13; 
const int FRONT_ECHO = 12;
const int SIDE_TRIG = 32;
const int SIDE_ECHO = 35; // Left side sensor

// ==========================================
// 2. PWM & THRESHOLDS (11.1V Setup)
// ==========================================
const int freq = 1000;           
const int resolution = 8;        
const int BASE_SPEED = 120;      
const int TURN_SPEED = 220;      // INCREASED: Much higher for aggressive pivoting      
const int FRONT_STOP_DIST = 20;  
const int SIDE_TARGET_DIST = 15; 

// ==========================================
// 3. STATE MACHINE
// ==========================================
enum RobotState {
  STATE_KICKSTART,        
  STATE_PATROL,           
  STATE_WRAP_REVERSE,     
  STATE_WRAP_FORWARD,     
  STATE_HUNT_LEFT,        
  STATE_EVADE_STOP_1,     
  STATE_EVADE_BACKUP,     
  STATE_EVADE_PIVOT,      
  STATE_EVADE_STOP_2
};

RobotState currentState = STATE_KICKSTART; 
unsigned long actionStartTime = 0;
unsigned long patrolStartTime = 0;
bool patrolFinished = false;

// Helper prototypes
long getDistance(int trigPin, int echoPin);
void moveForward(int sL, int sR);
void moveBackward(int sL, int sR);
void stopMotors();

void setup() {
  Serial.begin(115200);
  pinMode(IN1_PIN, OUTPUT); pinMode(IN2_PIN, OUTPUT);
  pinMode(IN3_PIN, OUTPUT); pinMode(IN4_PIN, OUTPUT);
  ledcAttach(ENA_PIN, freq, resolution);
  ledcAttach(ENB_PIN, freq, resolution);
  pinMode(FRONT_TRIG, OUTPUT); pinMode(FRONT_ECHO, INPUT);
  pinMode(SIDE_TRIG, OUTPUT); pinMode(SIDE_ECHO, INPUT);
  
  delay(10000); 
  patrolStartTime = millis(); 
  actionStartTime = millis(); 
}

void loop() {
  // Global Timer
  if (millis() - patrolStartTime >= 60000) {
    if (!patrolFinished) { stopMotors(); patrolFinished = true; }
    return;
  }

  // --- SAFETY INTERCEPT: CRASH PREVENTION ---
  long frontDist = getDistance(FRONT_TRIG, FRONT_ECHO);
  if (frontDist > 0 && frontDist <= FRONT_STOP_DIST && currentState != STATE_EVADE_STOP_1) {
    stopMotors();
    currentState = STATE_EVADE_STOP_1;
    actionStartTime = millis();
  }

  switch (currentState) {
    case STATE_KICKSTART:
      moveForward(250, 250); 
      if (millis() - actionStartTime >= 75) currentState = STATE_PATROL;
      break;

    // =========================================================
    // STATE: NORMAL PATROL
    // =========================================================
    case STATE_PATROL: {
      long sideDist = getDistance(SIDE_TRIG, SIDE_ECHO);
      
      // Wall lost: Hit a corner (room corner or box corner)
      if (sideDist >= 40 || sideDist == 999) {
        currentState = STATE_WRAP_REVERSE;
        actionStartTime = millis();
      } else {
        // Standard wall following
        if (sideDist < (SIDE_TARGET_DIST - 3)) moveForward(BASE_SPEED, 80);
        else if (sideDist > (SIDE_TARGET_DIST + 5)) moveForward(80, BASE_SPEED);
        else moveForward(BASE_SPEED, BASE_SPEED);
      }
      break;
    }

    // =========================================================
    // STATES: THE 3-PART WRAP & HUNT MANEUVER
    // =========================================================
    case STATE_WRAP_REVERSE:
      // Snap backward/right to clear the back wheels
      moveBackward(40, 190); 
      
      // INCREASED: Now holds the reverse hook for 650ms
      if (millis() - actionStartTime >= 650) { 
        currentState = STATE_WRAP_FORWARD;
        actionStartTime = millis();
      }
      break;

    case STATE_WRAP_FORWARD:
      // TIGHT Blind curve left to round the physical corner
      moveForward(50, BASE_SPEED);
      
      // INCREASED: Commits to the blind curve for 900ms before checking the sensor
      if (millis() - actionStartTime >= 900) {
        currentState = STATE_HUNT_LEFT; 
      }
      break;

    case STATE_HUNT_LEFT: {
      // Continuously carve a tight left circle...
      moveForward(50, BASE_SPEED);
      
      // ...until the side sensor finally sees the new wall/side of the box
      long sideDist = getDistance(SIDE_TRIG, SIDE_ECHO);
      if (sideDist > 0 && sideDist < 35) {
        Serial.println("Found the wall again! Resuming patrol.");
        currentState = STATE_PATROL; 
      }
      delay(50); // Small delay for sensor stability while hunting
      break;
    }

    // =========================================================
    // STATES: EVASION SEQUENCE (Wall is on LEFT, evade RIGHT)
    // =========================================================
    case STATE_EVADE_STOP_1:
      if (millis() - actionStartTime >= 500) {
        moveBackward(BASE_SPEED, BASE_SPEED);
        currentState = STATE_EVADE_BACKUP;
        actionStartTime = millis();
      }
      break;

    case STATE_EVADE_BACKUP:
      if (millis() - actionStartTime >= 600) {
        // Pivot Right away from the left wall (Now using the much higher TURN_SPEED)
        digitalWrite(IN1_PIN, HIGH); digitalWrite(IN2_PIN, LOW);
        digitalWrite(IN3_PIN, LOW); digitalWrite(IN4_PIN, HIGH);
        ledcWrite(ENA_PIN, TURN_SPEED); ledcWrite(ENB_PIN, TURN_SPEED);
        currentState = STATE_EVADE_PIVOT;
        actionStartTime = millis();
      }
      break;

    case STATE_EVADE_PIVOT:
      if (millis() - actionStartTime >= 500) {
        stopMotors();
        currentState = STATE_KICKSTART;
      }
      break;
  }
}

// ==========================================
// HELPER FUNCTIONS
// ==========================================
long getDistance(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW); delayMicroseconds(2);
  digitalWrite(trigPin, HIGH); delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  long d = pulseIn(echoPin, HIGH, 20000);
  return (d == 0) ? 999 : (d * 0.034 / 2);
}

void moveForward(int sL, int sR) {
  digitalWrite(IN1_PIN, HIGH); digitalWrite(IN2_PIN, LOW);
  digitalWrite(IN3_PIN, HIGH); digitalWrite(IN4_PIN, LOW);
  ledcWrite(ENA_PIN, sL); ledcWrite(ENB_PIN, sR);
}

void moveBackward(int sL, int sR) {
  digitalWrite(IN1_PIN, LOW); digitalWrite(IN2_PIN, HIGH);
  digitalWrite(IN3_PIN, LOW); digitalWrite(IN4_PIN, HIGH);
  ledcWrite(ENA_PIN, sL); ledcWrite(ENB_PIN, sR);
}

void stopMotors() {
  digitalWrite(IN1_PIN, LOW); digitalWrite(IN2_PIN, LOW);
  digitalWrite(IN3_PIN, LOW); digitalWrite(IN4_PIN, LOW);
  ledcWrite(ENA_PIN, 0); ledcWrite(ENB_PIN, 0);
}
