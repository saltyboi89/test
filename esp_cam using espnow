/* * ESP32-CAM: Distributed Patrol Node
 * *** ESP-NOW TRIGGER + AI INFERENCING + BASE64 FIREBASE UPLOAD ***
 */

#include <esp_now.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include "mbedtls/base64.h" 

// IMPORTANT: Make sure this matches your downloaded Edge Impulse library!
#include <esp_inferencing.h> 
#include "edge-impulse-sdk/dsp/image/image.hpp"
#include "esp_camera.h"

// --- WI-FI & FIREBASE SETTINGS ---
const char* ssid = "yakoub"; 
const char* password = "12345678";
const char* firebaseUrl = "https://safehouse-rover-default-rtdb.asia-southeast1.firebasedatabase.app/robots/camera_alert.json"; 

// --- AI THINKER PINS ---
#define PWDN_GPIO_NUM     32
#define RESET_GPIO_NUM    -1
#define XCLK_GPIO_NUM      0
#define SIOD_GPIO_NUM     26
#define SIOC_GPIO_NUM     27
#define Y9_GPIO_NUM       35
#define Y8_GPIO_NUM       34
#define Y7_GPIO_NUM       39
#define Y6_GPIO_NUM       36
#define Y5_GPIO_NUM       21
#define Y4_GPIO_NUM       19
#define Y3_GPIO_NUM       18
#define Y2_GPIO_NUM        5
#define VSYNC_GPIO_NUM    25
#define HREF_GPIO_NUM     23
#define PCLK_GPIO_NUM     22

// --- GLOBALS ---
camera_fb_t *locked_fb = NULL; 
bool triggerReceived = false;

// Edge Impulse config
#define EI_CAMERA_RAW_FRAME_BUFFER_COLS           320
#define EI_CAMERA_RAW_FRAME_BUFFER_ROWS           240
#define EI_CAMERA_FRAME_BYTE_SIZE                 3
uint8_t *snapshot_buf;

// --- ESP-NOW CALLBACK ---
// NOTE: New esp_now_recv_cb_t signature (ESP32 core 3.x / IDF 5.x) takes
// esp_now_recv_info* instead of a raw MAC address pointer.
void OnDataRecv(const esp_now_recv_info *info, const uint8_t *incomingData, int len) {
  char command[10];
  if (len >= (int)sizeof(command)) {
    len = sizeof(command) - 1; // safety clamp to avoid buffer overrun
  }
  memcpy(command, incomingData, len);
  command[len] = '\0'; 

  if (String(command) == "TAKE_PIC") {
    Serial.println("\n[CAM] >>> ESP-NOW TRIGGER RECEIVED! <<<");
    triggerReceived = true; 
  }
}

// --- BOOT ESP-NOW MODE ---
void start_esp_now_mode() {
  WiFi.mode(WIFI_STA);
  WiFi.disconnect(); 
  
  if (esp_now_init() != ESP_OK) {
    Serial.println("Error initializing ESP-NOW");
    return;
  }
  
  esp_now_register_recv_cb(OnDataRecv);
  Serial.println("[CAM] ESP-NOW Active. Listening for Main Board...");
}

void setup() {
  Serial.begin(115200); 
  Serial.println("\n--- Initializing ESP32-CAM (ESP-NOW + AI + Firebase) ---");

  // 1. Init Camera
  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer = LEDC_TIMER_0;
  config.pin_d0 = Y2_GPIO_NUM; config.pin_d1 = Y3_GPIO_NUM; config.pin_d2 = Y4_GPIO_NUM;
  config.pin_d3 = Y5_GPIO_NUM; config.pin_d4 = Y6_GPIO_NUM; config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM; config.pin_d7 = Y9_GPIO_NUM; config.pin_xclk = XCLK_GPIO_NUM;
  config.pin_pclk = PCLK_GPIO_NUM; config.pin_vsync = VSYNC_GPIO_NUM; config.pin_href = HREF_GPIO_NUM;
  config.pin_sccb_sda = SIOD_GPIO_NUM; config.pin_sccb_scl = SIOC_GPIO_NUM; config.pin_pwdn = PWDN_GPIO_NUM;
  config.pin_reset = RESET_GPIO_NUM;
  config.xclk_freq_hz = 20000000;
  config.pixel_format = PIXFORMAT_JPEG;
  config.frame_size = FRAMESIZE_QVGA; 
  config.jpeg_quality = 15;  // slightly higher = smaller file = faster upload
  config.fb_count = 1;
  config.fb_location = CAMERA_FB_IN_PSRAM;
  
  if (esp_camera_init(&config) != ESP_OK) {
    Serial.println("Camera Init Failed! Check pins/power.");
    while(true); 
  }

  // 1b. FIX UPSIDE-DOWN IMAGE
  // The OV2640 sensor on AI-Thinker boards is often mounted rotated 180°.
  // Flip vertically (and mirror horizontally) to correct orientation.
  sensor_t * s = esp_camera_sensor_get();
  if (s != NULL) {
    s->set_vflip(s, 1);     // 1 = flip image vertically
    s->set_hmirror(s, 1);   // 1 = mirror image horizontally (set to 0 if it looks wrong)
    Serial.println("[CAM] Applied vflip + hmirror to correct orientation.");
  }
  
  // 2. Boot into listening mode
  start_esp_now_mode();
}

void loop() {
  if (triggerReceived) {
    triggerReceived = false; 
    
    // 1. SHUT DOWN ESP-NOW
    Serial.println("[CAM] Shutting down ESP-NOW to free the antenna...");
    esp_now_deinit(); 
    
    // 2. CONNECT TO WI-FI
    Serial.println("[CAM] Connecting to Wi-Fi...");
    WiFi.begin(ssid, password);
    
    int attempts = 0;
    while (WiFi.status() != WL_CONNECTED && attempts < 20) {
      delay(500);
      Serial.print(".");
      attempts++;
    }

    if (WiFi.status() == WL_CONNECTED) {
      Serial.print("\n[CAM] Wi-Fi Connected! IP: ");
      Serial.println(WiFi.localIP());
      
      // 3. CAPTURE IMAGE
      Serial.println("Snapping photo...");
      locked_fb = esp_camera_fb_get();
      if (!locked_fb) {
        Serial.println("Camera capture failed!");
      } else {
        
        // 4. RUN AI MODEL
        snapshot_buf = (uint8_t*)malloc(EI_CAMERA_RAW_FRAME_BUFFER_COLS * EI_CAMERA_RAW_FRAME_BUFFER_ROWS * EI_CAMERA_FRAME_BYTE_SIZE);
        if(snapshot_buf == nullptr) {
            Serial.println("Failed to allocate RAM for AI.");
            esp_camera_fb_return(locked_fb);
        } else {
            // Convert JPEG to raw RGB
            fmt2rgb888(locked_fb->buf, locked_fb->len, PIXFORMAT_JPEG, snapshot_buf);

            // Resize fix for AI
            if ((EI_CLASSIFIER_INPUT_WIDTH != EI_CAMERA_RAW_FRAME_BUFFER_COLS) || 
                (EI_CLASSIFIER_INPUT_HEIGHT != EI_CAMERA_RAW_FRAME_BUFFER_ROWS)) {
                
                ei::image::processing::crop_and_interpolate_rgb888(
                  snapshot_buf,
                  EI_CAMERA_RAW_FRAME_BUFFER_COLS,
                  EI_CAMERA_RAW_FRAME_BUFFER_ROWS,
                  snapshot_buf,
                  EI_CLASSIFIER_INPUT_WIDTH,
                  EI_CLASSIFIER_INPUT_HEIGHT);
            }

            Serial.println("Running AI Analysis...");
            ei::signal_t signal;
            signal.total_length = EI_CLASSIFIER_INPUT_WIDTH * EI_CLASSIFIER_INPUT_HEIGHT;
            signal.get_data = &ei_camera_get_data;
            ei_impulse_result_t result = { 0 };
            run_classifier(&signal, &result, false);

            // Analyze Results 
            String bestLabel = "none";
            float bestScore = 0.0;
            
            #if EI_CLASSIFIER_OBJECT_DETECTION == 1
              for (uint32_t i = 0; i < result.bounding_boxes_count; i++) {
                if (result.bounding_boxes[i].value > bestScore) {
                  bestLabel = String(result.bounding_boxes[i].label);
                  bestScore = result.bounding_boxes[i].value;
                }
              }
            #else
              for (uint16_t i = 0; i < EI_CLASSIFIER_LABEL_COUNT; i++) {
                if (result.classification[i].value > bestScore) {
                  bestLabel = String(ei_classifier_inferencing_categories[i]);
                  bestScore = result.classification[i].value;
                }
              }
            #endif

            Serial.print("Top Prediction: ");
            Serial.print(bestLabel);
            Serial.print(" (");
            Serial.print(bestScore * 100);
            Serial.println("%)");

            // CRITICAL: Free AI Memory immediately to make room for Base64 Conversion
            free(snapshot_buf); 

            // 5. UPLOAD TO FIREBASE
            Serial.println("AI finished. Encoding image to Base64 and uploading...");
            uploadImageToFirebase(bestLabel, bestScore, locked_fb);

            // 6. FREE CAMERA MEMORY
            esp_camera_fb_return(locked_fb); 
            locked_fb = NULL;
        }
      }
    } else {
      Serial.println("\n[CAM] Wi-Fi failed to connect. Aborting upload.");
    }

    // 7. CLEAN UP & RESTORE ESP-NOW
    Serial.println("[CAM] Disconnecting Wi-Fi and returning to Standby Mode.\n");
    WiFi.disconnect();
    delay(100); 
    start_esp_now_mode(); 
  }
}

// --- HELPER FUNCTIONS ---
int ei_camera_get_data(size_t offset, size_t length, float *out_ptr) {
    size_t pixel_ix = offset * 3;
    size_t pixels_left = length;
    size_t out_ptr_ix = 0;
    while (pixels_left != 0) {
        out_ptr[out_ptr_ix] = (snapshot_buf[pixel_ix + 2] << 16) + (snapshot_buf[pixel_ix + 1] << 8) + snapshot_buf[pixel_ix];
        out_ptr_ix++; pixel_ix+=3; pixels_left--;
    }
    return 0;
}

void uploadImageToFirebase(String type, float confidence, camera_fb_t *fb) {
  if(WiFi.status() == WL_CONNECTED){
    
    // Calculate Base64 size and allocate memory safely
    size_t output_len;
    size_t encoded_len = ((fb->len + 2) / 3) * 4 + 1; 
    unsigned char * base64_buf = (unsigned char *) malloc(encoded_len);
    
    if(base64_buf == NULL) {
      Serial.println("ERROR: Out of Memory for Base64 encoding!");
      return;
    }

    // Encode the raw JPEG array into a Base64 String
    mbedtls_base64_encode(base64_buf, encoded_len, &output_len, fb->buf, fb->len);
    String imageString = String((char*)base64_buf);
    
    free(base64_buf); 

    // Connect to Firebase
    HTTPClient http;
    http.begin(firebaseUrl);
    http.setTimeout(15000);  // 15s timeout — was defaulting too short, causing error -11
    http.addHeader("Content-Type", "application/json");
    
    // Construct JSON Payload
    String payload = "{\"status\":\"debug_test\", \"type\":\"" + type + "\", \"confidence\":" + String(confidence * 100, 2) + ", \"image_data\":\"" + imageString + "\"}";
    
    Serial.print("Payload size (bytes): ");
    Serial.println(payload.length());

    // Upload via PATCH
    int httpResponseCode = http.PATCH(payload); 
    
    Serial.print("Firebase Update Response Code: ");
    Serial.println(httpResponseCode); // 200 = Success
    http.end();
    
  } else {
    Serial.println("Error: Wi-Fi disconnected during Firebase update.");
  }
}
